# author.today — ID книги (в URL сайта параметр workId)
AT_BOOK_ID=323389
# AT_WORK_ID=323389
AT_VALUE_TYPE=hit
AT_EMAIL=your@email.com
AT_PASSWORD=your_password

# Браузер (AT_HEADLESS=1 по умолчанию — без окна; 0 — показать Chrome)
CHROME_USER_DATA_DIR=
AT_HEADLESS=1
AT_PAGE_TIMEOUT=45
AT_WAIT_LOGIN=0
AT_AUTH_TIMEOUT=120

# MS SQL Server (вариант 1 — полная строка)
# MSSQL_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost;DATABASE=AuthorToday;UID=sa;PWD=secret;TrustServerCertificate=yes

# MS SQL Server (вариант 2 — отдельные поля)
MSSQL_SERVER=localhost
MSSQL_DATABASE=AuthorToday
MSSQL_USER=sa
MSSQL_PASSWORD=your_password
MSSQL_DRIVER=ODBC Driver 17 for SQL Server
MSSQL_TRUST_SERVER_CERTIFICATE=yes

# Windows-авторизация вместо MSSQL_USER/MSSQL_PASSWORD
# MSSQL_TRUSTED_CONNECTION=yes

# Устаревшие JSON-снимки в data/raw (отладка CLI --json)
# AT_ENABLE_LEGACY_JSON=yes
